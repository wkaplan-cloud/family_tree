generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConsentStatus {
  unknown
  invited
  verified
  unsubscribed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  people    Person[] @relation("CreatedPeople")
}

model Person {
  id            String         @id @default(cuid())
  name          String
  alive         Boolean        @default(true)
  email         String?
  notes         String?
  consentStatus ConsentStatus  @default(unknown)
  createdAt     DateTime       @default(now())
  createdById   String
  createdBy     User           @relation("CreatedPeople", fields: [createdById], references: [id])
  invites       Invite[]
  leftLinks     Relationship[] @relation("LeftPerson")
  rightLinks    Relationship[] @relation("RightPerson")
}

model Relationship {
  id        String   @id @default(cuid())
  label     String
  createdAt DateTime @default(now())
  leftId    String
  rightId   String
  left      Person   @relation("LeftPerson", fields: [leftId], references: [id])
  right     Person   @relation("RightPerson", fields: [rightId], references: [id])
}

model Invite {
  id               String   @id @default(cuid())
  token            String   @unique
  recipientName    String
  recipientEmail   String
  inviterName      String
  remindersEnabled Boolean  @default(true)
  remindersSent    Int      @default(0)
  openedAt         DateTime?
  clickedAt        DateTime?
  contributedAt    DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime @default(now())
  personId         String
  person           Person   @relation(fields: [personId], references: [id])
}
